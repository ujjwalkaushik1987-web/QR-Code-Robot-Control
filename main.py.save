import cv2
import time
from commands import execute_command

cap = cv2.VideoCapture(0, cv2.CAP_AVFOUNDATION)
detector = cv2.QRCodeDetector()

last_data = ""
last_time = 0
history = []

print("📷 QR Scanner Started (Press Q to exit)")

while True:
    ret, frame = cap.read()

    if not ret:
        print("❌ Camera not working")
        break

    data, bbox, _ = detector.detectAndDecode(frame)

    if bbox is not None and data:
        data = data.strip()
        current_time = time.time()

        # ✅ Smart detection (no repeat + delay)
        if data != last_data or (current_time - last_time > 3):
            print("Detected:", data)

            result = execute_command(data)

            last_data = data
            last_time = current_time

            history.append(result)
            if len(history) > 5:
                history.pop(0)

            time.sleep(1)

        # 🎨 Color logic
        color = (0, 255, 0)
        if data == "STOP":
            color = (0, 0, 255)
        elif data == "LEFT":
            color = (255, 0, 0)
        elif data == "RIGHT":
            color = (0, 255, 255)
        elif data == "LIGHT ON":
            color = (255, 255, 0)

        # 📦 Draw QR box
        for i in range(len(bbox)):
            pt1 = tuple(map(int, bbox[i][0]))
            pt2 = tuple(map(int, bbox[(i+1) % len(bbox)][0]))
            cv2.line(frame, pt1, pt2, color, 3)

    # 🖤 DARK HEADER UI
    overlay = frame.copy()
    cv2.rectangle(overlay, (0, 0), (640, 150), (0, 0, 0), -1)
    cv2.addWeighted(overlay, 0.6, frame, 0.4, 0, frame)

    # 🎨 Dynamic text color
    if last_data == "STOP":
        text_color = (0,0,255)
    elif last_data == "LEFT":
        text_color = (255,0,0)
    elif last_data == "RIGHT":
        text_color = (0,255,255)
    else:
        text_color = (0,255,0)

    # 🖥️ Title
    cv2.putText(frame, "QR COMMAND SYSTEM", (30, 40),
                cv2.FONT_HERSHEY_SIMPLEX, 1, (0,255,255), 3)

    # 🎯 Current Command
    cv2.putText(frame, f"Command: {last_data}", (30, 90),
                cv2.FONT_HERSHEY_SIMPLEX, 1, text_color, 3)

    # 📊 Status
    cv2.putText(frame, "Status: ACTIVE", (30, 130),
                cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255,255,255), 2)

    # 📜 History Panel
    y = 200
    cv2.putText(frame, "History:", (30, y),
                cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255,255,255), 2)

    for item in history:
        y += 30
        cv2.putText(frame, item, (30, y),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (200,200,200), 2)

    cv2.imshow("QR Command System PRO", frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
     
